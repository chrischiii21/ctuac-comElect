---
import '../styles/global.css';
import { Landmark, ShieldAlert, Clock } from 'lucide-react';
---

<!doctype html>
<html lang="en" class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/jpeg" href="/logo.jpg" />
		<title>Election Closed | CTU-AC COMELEC</title>
		<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700&family=Inter:wght@400;500;700&display=swap" rel="stylesheet">
	</head>
	<body class="bg-black text-white font-inter selection:bg-brand-coral/30 flex items-center justify-center min-h-screen p-6">
		<div class="max-w-md w-full text-center space-y-12">
			<!-- Logo Section -->
			<div class="relative inline-block">
				<div class="absolute inset-0 bg-brand-coral/20 blur-3xl rounded-full"></div>
				<img src="/logo.jpg" alt="CTU Logo" class="relative w-24 h-24 mx-auto rounded-full shadow-[0_0_50px_rgba(255,85,85,0.2)] border-2 border-brand-coral/20" />
			</div>

			<!-- Message Section -->
			<div class="space-y-6">
				<div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-brand-coral/10 border border-brand-coral/20 text-brand-coral text-xs font-bold uppercase tracking-widest animate-pulse">
					<ShieldAlert size={14} />
					Access Restricted
				</div>
				<h1 class="text-4xl font-outfit font-bold tracking-tight">Student Voting is Currently Closed</h1>
				<p class="text-white/40 leading-relaxed">
					The election period has either ended or has been temporarily paused by the CTU-AC Commission on Elections.
				</p>
			</div>

			<!-- Status Info -->
			<div class="bento-card bg-white/[0.02] border-white/5 p-8 text-left space-y-6">
				<div class="flex items-start gap-4">
					<div class="w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center text-white/40">
						<Clock size={20} />
					</div>
					<div>
						<h3 class="font-bold text-white/80">Check Schedule</h3>
						<p class="text-xs text-white/20 mt-1">Please refer to the official COMELEC announcements for the voting schedule and deadlines.</p>
					</div>
				</div>
				<div class="flex items-start gap-4">
					<div class="w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center text-white/40">
						<Landmark size={20} />
					</div>
					<div>
						<h3 class="font-bold text-white/80">Official Results</h3>
						<p class="text-xs text-white/20 mt-1">Consolidated results will be posted on the official campus notice boards after the tallying process.</p>
					</div>
				</div>
			</div>

			<!-- Footer -->
			<div class="pt-8 space-y-4">
				<div class="h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>
				<p class="text-[10px] text-white/20 uppercase tracking-[0.2em] font-bold">CTU-AC Commission on Elections</p>
			</div>
		</div>
	</body>
</html>

<style>
	body {
		background: 
			radial-gradient(circle at 50% 50%, rgba(255, 85, 85, 0.03) 0%, transparent 50%),
			black;
	}
</style>
