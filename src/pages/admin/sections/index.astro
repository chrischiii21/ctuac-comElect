---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { supabase } from '../../../lib/supabase';
import { Landmark, ArrowRight, Plus, Search } from 'lucide-react';

// Fetch all sections
const { data: sections } = await supabase
  .from('sections')
  .select('*')
  .order('name');

// Fetch counts for each section
const sectionsWithCounts = await Promise.all((sections || []).map(async (section) => {
  const { count: sTotal } = await supabase.from('students').select('*', { count: 'exact', head: true }).eq('section_id', section.id);
  const { count: sVoted } = await supabase.from('students').select('*', { count: 'exact', head: true }).eq('section_id', section.id).eq('has_voted', true);
  const sPercentage = sTotal ? Math.round((sVoted || 0) / sTotal * 100) : 0;
  return { ...section, sTotal, sVoted, sPercentage };
}));

// Grouping Logic
const collegeMapping: Record<string, string> = {
  'BEED': 'COED', 'BSED - Math': 'COED', 'BSED - English': 'COED', 'BTLED': 'COED',
  'BSTM': 'CHTM', 'BSHM': 'CHTM',
  'BAEL': 'CAS', 'BAL': 'CAS', 'BSP': 'CAS',
  'BSA': 'CAFE', 'BSF': 'CAFE', 'BSES': 'CAFE',
  'BIT-AT': 'COTE', 'BIT-ET': 'COTE', 'BIT-CT': 'COTE', 'BIT-GT': 'COTE', 'BIT-DT': 'COTE', 'BSIT': 'COTE', 'BSIE': 'COTE',
};

const groupedSections = sectionsWithCounts.reduce((acc, section) => {
  const college = collegeMapping[section.program || ''] || 'OTHER';
  const program = section.program || 'Other';
  
  if (!acc[college]) acc[college] = {};
  if (!acc[college][program]) acc[college][program] = [];
  
  acc[college][program].push(section);
  return acc;
}, {} as Record<string, Record<string, any[]>>);

const sortedColleges = Object.keys(groupedSections).sort();
---

<AdminLayout title="Manage Sections">
	<div class="max-w-7xl mx-auto px-6 py-12 space-y-12">
		<header class="flex flex-col md:flex-row md:items-center justify-between gap-6">
			<div>
				<h1 class="text-5xl font-outfit font-bold tracking-tight mb-2">Sections</h1>
				<p class="text-white/40 max-w-xl">Manage all voting sections and track their real-time turnout progress.</p>
			</div>
			<button onclick="document.getElementById('upload-modal').showModal()" class="btn-primary flex items-center gap-2">
				<Plus size={20} />
				Import New Section
			</button>
		</header>

		<!-- Search Bar -->
		<div class="relative max-w-md">
			<div class="absolute inset-y-0 left-4 flex items-center pointer-events-none text-white/20">
				<Search size={18} />
			</div>
			<input 
				type="text" 
				id="section-search"
				placeholder="Search by section name or program..." 
				class="w-full bg-white/5 border border-white/10 rounded-2xl pl-12 pr-4 py-4 focus:outline-none focus:border-emerald-500/50 transition-all text-sm text-white placeholder:text-white/20 shadow-inner"
			/>
		</div>

		<div class="space-y-16">
			{sortedColleges.map((college) => (
				<div class="college-group space-y-8" data-college={college}>
					<div class="flex items-center gap-4">
						<div class="h-px flex-1 bg-gradient-to-r from-transparent to-white/10"></div>
						<h2 class="text-2xl font-outfit font-bold tracking-tight text-white/40 uppercase tracking-[0.2em]">{college}</h2>
						<div class="h-px flex-1 bg-gradient-to-l from-transparent to-white/10"></div>
					</div>

					<div class="space-y-12">
						{Object.keys(groupedSections[college]).sort().map((program) => (
							<div class="program-group space-y-6" data-program={program}>
								<div class="flex items-center gap-2">
									<div class="w-1.5 h-1.5 rounded-full bg-emerald-500/50"></div>
									<h3 class="text-sm font-bold text-white/20 uppercase tracking-widest">{program}</h3>
								</div>

								<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
									{groupedSections[college][program].map((section) => (
										<a 
											href={`/admin/sections/${section.id}`} 
											class="section-card bento-card group hover:border-emerald-500/30 transition-all"
											data-name={section.name.toLowerCase()}
											data-program={section.program?.toLowerCase() || ''}
										>
											<div class="flex justify-between items-start mb-6">
												<div class="w-12 h-12 bg-white/5 rounded-2xl flex items-center justify-center text-white/20 group-hover:bg-emerald-500/10 group-hover:text-emerald-500 transition-colors">
													<Landmark size={24} />
												</div>
												<div class="flex flex-col items-end gap-2">
													<div class="status-badge status-badge-voted">Active</div>
													{section.is_manual && (
														<span class="px-2 py-0.5 rounded-md bg-brand-coral/10 border border-brand-coral/20 text-[8px] font-bold uppercase tracking-widest text-brand-coral">Manual Tally</span>
													)}
												</div>
											</div>
											
											<div class="space-y-4">
												<div>
													<h3 class="text-xl font-bold">{section.name}</h3>
													<p class="text-xs font-mono text-white/20 uppercase tracking-tighter">
														{section.is_manual ? 'Manual Record Entry' : `Token: ${section.token.slice(0, 12)}...`}
													</p>
												</div>

												{!section.is_manual && (
													<div class="space-y-2">
														<div class="flex justify-between items-end">
															<span class="text-[10px] font-bold uppercase tracking-widest text-white/20">Turnout</span>
															<span class="text-sm font-mono font-bold text-emerald-400">{section.sPercentage}%</span>
														</div>
														<div class="w-full h-1.5 bg-white/5 rounded-full overflow-hidden">
															<div class="h-full bg-emerald-500 transition-all duration-1000" style={`width: ${section.sPercentage}%`}></div>
														</div>
														<div class="flex justify-between text-[10px] text-white/40 font-mono">
															<span>{section.sVoted} Voted</span>
															<span>{section.sTotal} Total</span>
														</div>
													</div>
												)}
											</div>

											<div class="mt-6 pt-6 border-t border-white/5 flex items-center justify-between text-xs font-bold uppercase tracking-widest text-white/20 group-hover:text-white transition-colors">
												{section.is_manual ? 'View Tally Results' : 'View Student List'}
												<ArrowRight size={14} class="group-hover:translate-x-1 transition-transform" />
											</div>
										</a>
									))}
								</div>
							</div>
						))}
					</div>
				</div>
			))}

			{sectionsWithCounts.length === 0 && (
				<div class="col-span-full bento-card p-24 flex flex-col items-center justify-center text-center space-y-6 border-dashed border-white/5 bg-transparent">
					<div class="w-20 h-20 bg-white/5 rounded-3xl flex items-center justify-center text-white/20">
						<Landmark size={40} />
					</div>
					<div class="space-y-2">
						<h3 class="text-2xl font-bold text-white/60">No sections found</h3>
						<p class="text-white/20 max-w-sm mx-auto">Upload a student CSV list to create your first election section.</p>
					</div>
					<button onclick="document.getElementById('upload-modal').showModal()" class="btn-primary">Import First Section</button>
				</div>
			)}
		</div>
	</div>

	<!-- Reuse the same Upload Modal logic -->
	<dialog id="upload-modal" class="bg-brand-black border border-white/10 rounded-3xl p-0 overflow-hidden max-w-md w-full">
		<div class="p-8">
			<h3 class="text-2xl font-outfit font-semibold mb-2 text-white">Import Student List</h3>
			<p class="text-white/60 text-sm mb-6">Upload a CSV file containing student IDs and Full Names for a specific section.</p>
			
			<form action="/api/upload-section" method="POST" enctype="multipart/form-data" class="space-y-6">
				<div class="space-y-2">
					<label class="text-[10px] font-bold uppercase tracking-widest text-white/80">Section Name</label>
					<input 
						type="text" 
						name="sectionName" 
						placeholder="e.g. BSIT-4A" 
						required 
						class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 focus:outline-none focus:border-emerald-500 transition-colors text-white placeholder:text-white/20"
					/>
				</div>
				<div class="space-y-2">
					<label class="text-[10px] font-bold uppercase tracking-widest text-white/80">Department</label>
					<select 
						name="program" 
						required 
						class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 focus:outline-none focus:border-emerald-500 transition-colors text-white appearance-none cursor-pointer"
					>
						<option value="" disabled selected class="bg-brand-black">Select Department</option>
						<optgroup label="Education (COED)" class="bg-brand-black">
							<option value="BEED">BEED</option>
							<option value="BSED - Math">BSED - Math</option>
							<option value="BSED - English">BSED - English</option>
							<option value="BTLED">BTLED</option>
						</optgroup>
						<optgroup label="Hospitality Management (CHTM)" class="bg-brand-black">
							<option value="BSTM">BSTM</option>
							<option value="BSHM">BSHM</option>
						</optgroup>
						<optgroup label="Arts & Sciences (CAS)" class="bg-brand-black">
							<option value="BAEL">BAEL</option>
							<option value="BAL">BAL</option>
							<option value="BSP">BSP</option>
						</optgroup>
						<optgroup label="Agriculture & Forestry (CAFE)" class="bg-brand-black">
							<option value="BSA">BSA</option>
							<option value="BSF">BSF</option>
							<option value="BSES">BSES</option>
						</optgroup>
						<optgroup label="Technology & Engineering (COTE)" class="bg-brand-black">
							<option value="BIT-AT">BIT-AT</option>
							<option value="BIT-ET">BIT-ET</option>
							<option value="BIT-CT">BIT-CT</option>
							<option value="BIT-GT">BIT-GT</option>
							<option value="BIT-DT">BIT-DT</option>
							<option value="BSIT">BSIT</option>
							<option value="BSIE">BSIE</option>
						</optgroup>
						<optgroup label="Business & IT (CBIT)" class="bg-brand-black">
							<option value="BSIT">BSIT</option>
						</optgroup>
					</select>
				</div>
				<div class="space-y-2">
					<label class="text-[10px] font-bold uppercase tracking-widest text-white/80">CSV File</label>
					<label class="block w-full border-2 border-dashed border-white/10 rounded-2xl p-8 hover:border-emerald-500/50 hover:bg-emerald-500/5 transition-all cursor-pointer group">
						<input 
							type="file" 
							name="csvFile" 
							accept=".csv" 
							required 
							class="hidden" 
							onchange="const span = document.getElementById('filename-display-sections'); span.textContent = this.files[0].name; span.classList.add('text-emerald-500'); span.classList.remove('text-white/40');"
						/>
						<div class="flex flex-col items-center gap-2 text-center">
							<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white/20 group-hover:text-emerald-500 transition-colors"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="17 8 12 3 7 8"></polyline><line x1="12" x2="12" y1="3" y2="15"></line></svg>
							<span id="filename-display-sections" class="text-sm text-white/40 group-hover:text-white/60 transition-colors truncate max-w-full px-4">
								Drop CSV or Click to Browse
							</span>
						</div>
					</label>
				</div>

				<div class="flex gap-4 pt-4">
					<button type="button" onclick="this.closest('dialog').close()" class="flex-1 px-6 py-3 rounded-xl border border-white/10 text-white/60 hover:bg-white/5 transition-colors">Cancel</button>
					<button type="submit" class="flex-1 bg-white text-black px-6 py-3 rounded-xl font-bold hover:bg-emerald-500 transition-colors">Start Import</button>
				</div>
			</form>
		</div>
	</dialog>
	<script>
		const searchInput = document.getElementById('section-search') as HTMLInputElement;
		const sectionCards = document.querySelectorAll('.section-card');
		const collegeGroups = document.querySelectorAll('.college-group');
		const programGroups = document.querySelectorAll('.program-group');

		searchInput?.addEventListener('input', (e) => {
			const query = (e.target as HTMLInputElement).value.toLowerCase();

			// 1. Filter individual cards
			sectionCards.forEach((card) => {
				const name = card.getAttribute('data-name') || '';
				const program = card.getAttribute('data-program') || '';
				
				if (name.includes(query) || program.includes(query)) {
					(card as HTMLElement).style.display = 'block';
				} else {
					(card as HTMLElement).style.display = 'none';
				}
			});

			// 2. Hide program headers if empty
			programGroups.forEach((group) => {
				const cards = group.querySelectorAll('.section-card');
				const hasVisible = Array.from(cards).some(c => (c as HTMLElement).style.display !== 'none');
				(group as HTMLElement).style.display = hasVisible ? 'block' : 'none';
			});

			// 3. Hide college headers if empty
			collegeGroups.forEach((group) => {
				const programs = group.querySelectorAll('.program-group');
				const hasVisible = Array.from(programs).some(p => (p as HTMLElement).style.display !== 'none');
				(group as HTMLElement).style.display = hasVisible ? 'block' : 'none';
			});
		});
	</script>
</AdminLayout>
