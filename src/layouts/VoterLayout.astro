---
import '../styles/global.css';
import Toaster from '../components/Toaster';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/jpeg" href="/logo.jpg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | CTU COMELEC</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600&family=Inter:wght@400;500;700&display=swap" rel="stylesheet">
	</head>
	<body class="bg-black text-white font-inter selection:bg-emerald-500/30">
		<Toaster client:load />
		<div class="min-h-screen flex flex-col">
			<main class="flex-1 flex flex-col items-center justify-center p-6">
				<slot />
			</main>
		</div>

		<script>
			import { checkUrlMessages } from '../lib/toasts';
			checkUrlMessages();
		</script>
	</body>
</html>
