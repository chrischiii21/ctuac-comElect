{
	"version": 3,
	"routes": [
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "^\\/_image$",
			"dest": "_render"
		},
		{
			"src": "^\\/admin\\/candidates\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/admin\\/sections\\/([^/]+?)\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/admin\\/sections\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/admin\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/api\\/upload-section\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/section\\/([^/]+?)\\/ballot\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/section\\/([^/]+?)\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/$",
			"dest": "_render"
		}
	]
}