---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { supabase, getSupabaseAdmin } from '../../lib/supabase';
import { Landmark, Plus, Minus, RotateCcw, Save, Hash, RefreshCcw, Trophy } from 'lucide-react';

// 1. Fetch Sections and Candidates
const { data: manualSections } = await supabase.from('sections').select('*').eq('is_manual', true).order('name');
const { data: candidates } = await supabase.from('candidates').select('*').order('position');

// 2. Fetch Manual Tally Totals for Live Standings
const { data: manualTallies } = await supabase.from('manual_tallies').select('candidate_id, votes');
const manualTotals = manualTallies?.reduce((acc, t) => {
  acc[t.candidate_id] = (acc[t.candidate_id] || 0) + t.votes;
  return acc;
}, {} as Record<string, number>) || {};

const positionPriority = (pos: string) => {
  const p = pos.toLowerCase();
  if (p === 'president') return 0;
  if (p === 'vice president') return 1;
  if (p.includes('senator')) return 2;
  if (p.includes('hr')) return 3;
  return 4;
};

// Sort candidates for the sidebar
const sortedCandidates = [...(candidates || [])].sort((a, b) => {
  const priorityA = positionPriority(a.position);
  const priorityB = positionPriority(b.position);
  if (priorityA !== priorityB) return priorityA - priorityB;
  return a.name.localeCompare(b.name);
});

const collegeMapping: Record<string, string> = {
  'BEED': 'CoEd', 'BSED - Math': 'CoEd', 'BSED - English': 'CoEd', 'BTLED': 'CoEd',
  'BSTM': 'CHTM', 'BSHM': 'CHTM',
  'BAEL': 'CAS', 'BAL': 'CAS', 'BSP': 'CAS',
  'BSA': 'CAFE', 'BSF': 'CAFE', 'BSES': 'CAFE',
  'BIT-AT': 'COTE', 'BIT-ET': 'COTE', 'BIT-CT': 'COTE', 'BIT-GT': 'COTE', 'BIT-DT': 'COTE', 'BSIT': 'COTE', 'BSIE': 'COTE',
};
---

<AdminLayout title="Manual Tally Station">
	<div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
		<!-- Right: Live Manual Standings (Priority Sidebar) -->
		<div class="lg:col-span-1 lg:order-last space-y-6">
			<div class="bg-white/[0.02] border border-white/5 p-6 rounded-3xl sticky top-24">
				<div class="flex items-center gap-3 mb-6">
					<div class="w-8 h-8 bg-brand-coral/10 text-brand-coral rounded-lg flex items-center justify-center">
						<Hash size={18} />
					</div>
					<h2 class="font-outfit font-bold text-lg">Manual Standings</h2>
				</div>

				<div class="space-y-8 max-h-[60vh] overflow-y-auto pr-2 custom-scrollbar">
					{['Executive Board', 'Senatorial', 'House Representatives'].map(category => {
						const filtered = sortedCandidates.filter(c => {
							const pos = c.position.toLowerCase();
							if (category === 'Executive Board') return pos === 'president' || pos === 'vice president';
							if (category === 'Senatorial') return pos.includes('senator');
							if (category === 'House Representatives') return pos.includes('hr');
							return false;
						});

						if (filtered.length === 0) return null;

						return (
							<div class="space-y-3">
								<h3 class="text-[10px] font-bold uppercase tracking-[0.2em] text-white/20 px-1">{category}</h3>
								
								{category === 'House Representatives' ? (
									// Sub-group by College
									(() => {
										const collegeMapping = {
											'BEED': 'COED', 'BSED': 'COED', 'BTLED': 'COED',
											'BSTM': 'CHTM', 'BSHM': 'CHTM',
											'BAEL': 'CAS', 'BAL': 'CAS', 'BSP': 'CAS',
											'BSA': 'CAFE', 'BSF': 'CAFE', 'BSES': 'CAFE',
											'BIT': 'COTE', 'BSIT': 'COTE', 'BSIE': 'COTE',
										};
										const colleges = ['COTE', 'CAFE', 'CHTM', 'CAS', 'COED', 'CBIT'];
										
										const hrByCollege = {};
										filtered.forEach(c => {
											let foundCollege = 'OTHER';
											const up = c.position.toUpperCase();
											for (const [prog, coll] of Object.entries(collegeMapping)) {
												if (up.includes(prog)) { foundCollege = coll; break; }
											}
											if (foundCollege === 'OTHER') {
												for (const coll of colleges) {
													if (up.includes(coll)) { foundCollege = coll; break; }
												}
											}
											if (!hrByCollege[foundCollege]) hrByCollege[foundCollege] = [];
											hrByCollege[foundCollege].push(c);
										});

										return Object.keys(hrByCollege).sort().map(college => (
											<div class="space-y-2 mt-4 first:mt-0">
												<div class="flex items-center gap-2 mb-2">
													<div class="w-1 h-1 rounded-full bg-brand-coral/40"></div>
													<h4 class="text-[9px] font-bold text-white/30 uppercase tracking-widest">{college}</h4>
												</div>
												{hrByCollege[college].map(c => {
													const total = manualTotals[c.id] || 0;
													const siblings = sortedCandidates.filter(s => s.position === c.position);
													const maxVotes = Math.max(...siblings.map(s => manualTotals[s.id] || 0));
													const isLeader = total > 0 && total === maxVotes;
													return (
														<div class={`flex items-center justify-between p-3 rounded-xl border transition-all duration-500 ${isLeader ? 'bg-brand-coral/10 border-brand-coral/30 shadow-[0_0_15px_rgba(255,85,85,0.1)]' : 'bg-white/[0.02] border-white/5'}`}>
															<div class="flex flex-col">
																<div class="flex items-center gap-2 mb-1">
																	<span class="text-[10px] font-bold uppercase tracking-widest text-white/40 leading-none">{c.position}</span>
																	{isLeader && <Trophy size={10} class="text-brand-coral" />}
																</div>
																<span class={`text-xs font-semibold truncate max-w-[120px] ${isLeader ? 'text-white' : 'text-white/60'}`}>{c.name}</span>
															</div>
															<div class={`text-lg font-outfit font-bold ${isLeader ? 'text-brand-coral scale-110' : 'text-white/40'}`} id={`total-${c.id}`}>{total}</div>
														</div>
													);
												})}
											</div>
										));
									})()
								) : (
									<div class="space-y-2">
										{filtered.map(c => {
											const total = manualTotals[c.id] || 0;
											const siblings = sortedCandidates.filter(s => s.position === c.position);
											const maxVotes = Math.max(...siblings.map(s => manualTotals[s.id] || 0));
											const isLeader = total > 0 && total === maxVotes;

											return (
												<div class={`flex items-center justify-between p-3 rounded-xl border transition-all duration-500 ${isLeader ? 'bg-brand-coral/10 border-brand-coral/30 shadow-[0_0_15px_rgba(255,85,85,0.1)]' : 'bg-white/[0.02] border-white/5'}`}>
													<div class="flex flex-col">
														<div class="flex items-center gap-2 mb-1">
															<span class="text-[10px] font-bold uppercase tracking-widest text-white/40 leading-none">{c.position}</span>
															{isLeader && <Trophy size={10} class="text-brand-coral" />}
														</div>
														<span class={`text-xs font-semibold truncate max-w-[120px] ${isLeader ? 'text-white' : 'text-white/60'}`}>{c.name}</span>
													</div>
													<div class={`text-lg font-outfit font-bold ${isLeader ? 'text-brand-coral scale-110' : 'text-white/40'}`} id={`total-${c.id}`}>{total}</div>
												</div>
											);
										})}
									</div>
								)}
							</div>
						);
					})}
				</div>

				<div class="mt-8 pt-8 border-t border-white/5">
					<a 
						href="/admin/consolidated"
						class="w-full py-4 bg-brand-coral/10 hover:bg-brand-coral/20 border border-brand-coral/20 rounded-2xl text-xs font-bold uppercase tracking-widest transition-all flex items-center justify-center gap-2 text-brand-coral"
					>
						<RefreshCcw size={16} /> Sync to Consolidated
					</a>
				</div>
			</div>
		</div>

		<!-- Left: Tally Station -->
		<div class="lg:col-span-3 lg:order-first space-y-8">
			<header class="flex flex-col md:flex-row md:items-center justify-between gap-6 bg-white/[0.02] border border-white/5 p-8 rounded-3xl">
				<div class="space-y-1">
					<h1 class="text-3xl font-outfit font-bold tracking-tight">Manual Tally Station</h1>
					<p class="text-white/40 text-sm">Select a section card to begin recording paper ballots.</p>
				</div>
				
				<div class="flex items-center gap-4">
					<div class="relative group">
						<div class="absolute inset-y-0 left-4 flex items-center pointer-events-none text-white/20 group-focus-within:text-brand-coral transition-colors">
							<Hash size={18} />
						</div>
						<input 
							type="text" 
							id="section-search" 
							placeholder="Search section..." 
							class="bg-black border border-white/10 rounded-xl pl-12 pr-4 py-3 text-sm focus:outline-none focus:border-brand-coral transition-all min-w-[240px]"
						/>
					</div>
					<button 
						onclick="document.getElementById('upload-modal').showModal()"
						class="btn-primary px-6 py-3 rounded-xl flex items-center gap-2 text-sm"
					>
						<Plus size={18} /> Add Section
					</button>
				</div>
			</header>

		<!-- Section Upload Modal (Consistent with Admin) -->
		<dialog id="upload-modal" class="bg-brand-black border border-white/10 rounded-3xl p-0 overflow-hidden max-w-md w-full shadow-[0_0_50px_rgba(0,0,0,0.5)] text-white">
			<form action="/api/upload-section" method="POST" enctype="multipart/form-data" class="p-8 space-y-6">
				<input type="hidden" name="isManual" value="true" />
				<div class="space-y-2">
					<h3 class="text-2xl font-outfit font-bold">Add New Section</h3>
					<p class="text-white/40 text-sm">Create a section to begin manual tallying.</p>
				</div>

				<div class="space-y-4">
					<div class="space-y-2">
						<label class="text-[10px] font-bold uppercase tracking-widest text-white/80">Section Name</label>
						<input 
							type="text" 
							name="sectionName" 
							placeholder="e.g. BSIT-4A" 
							required 
							class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 focus:outline-none focus:border-brand-coral transition-colors text-white placeholder:text-white/20"
						/>
					</div>
					<div class="space-y-2">
						<label class="text-[10px] font-bold uppercase tracking-widest text-white/80">Program / Department</label>
						<select name="program" required class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 focus:outline-none focus:border-brand-coral transition-colors appearance-none text-white">
							<optgroup label="College of Education (CoEd)">
								<option value="BEED">BEED</option>
								<option value="BSED - Math">BSED - Math</option>
								<option value="BSED - English">BSED - English</option>
								<option value="BTLED">BTLED</option>
							</optgroup>
							<optgroup label="Hospitality Management (CHTM)">
								<option value="BSTM">BSTM</option>
								<option value="BSHM">BSHM</option>
							</optgroup>
							<optgroup label="Arts and Sciences (CAS)">
								<option value="BAEL">BAEL</option>
								<option value="BAL">BAL</option>
								<option value="BSP">BSP</option>
							</optgroup>
							<optgroup label="Agriculture & Forestry (CAFE)">
								<option value="BSA">BSA</option>
								<option value="BSF">BSF</option>
								<option value="BSES">BSES</option>
							</optgroup>
							<optgroup label="Technology & Engineering (COTE)">
								<option value="BIT-AT">BIT-AT</option>
								<option value="BIT-ET">BIT-ET</option>
								<option value="BIT-CT">BIT-CT</option>
								<option value="BIT-GT">BIT-GT</option>
								<option value="BIT-DT">BIT-DT</option>
								<option value="BSIT">BSIT</option>
								<option value="BSIE">BSIE</option>
							</optgroup>
						</select>
					</div>
					<div class="p-4 bg-white/[0.02] border border-dashed border-white/10 rounded-xl">
						<p class="text-[10px] text-white/40 leading-relaxed italic">
							*Note: You can skip uploading a CSV for manual tallying. This will just create the section entry.
						</p>
					</div>
				</div>

				<div class="flex gap-3">
					<button type="button" onclick="this.closest('dialog').close()" class="flex-1 px-6 py-3 rounded-xl border border-white/10 text-white/60 hover:bg-white/5 transition-colors">Cancel</button>
					<button type="submit" class="flex-1 btn-primary py-3 rounded-xl font-bold">Create Section</button>
				</div>
			</form>
		</dialog>

			<!-- Sections Grid -->
			<div id="sections-container" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
				{manualSections?.map(s => (
					<button 
						onclick={`selectSection('${s.id}', '${s.name}', '${s.program || ''}')`}
						class="section-card group p-6 rounded-2xl bg-white/[0.02] border border-white/5 hover:border-brand-coral/50 hover:bg-brand-coral/5 transition-all text-left space-y-3"
						data-name={s.name.toLowerCase()}
					>
						<div class="flex items-center justify-between">
							<div class="w-10 h-10 bg-white/5 rounded-xl flex items-center justify-center text-white/40 group-hover:bg-brand-coral group-hover:text-white transition-colors">
								<Landmark size={20} />
							</div>
							<div class="text-[10px] font-bold uppercase tracking-widest text-white/20 group-hover:text-brand-coral/60">{s.program || 'N/A'}</div>
						</div>
						<div class="space-y-1">
							<h3 class="text-lg font-bold group-hover:text-white transition-colors">{s.name}</h3>
							<div class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md bg-white/5 border border-white/10 text-[8px] font-bold uppercase tracking-widest text-white/40 group-hover:bg-brand-coral/10 group-hover:border-brand-coral/20 group-hover:text-brand-coral transition-colors">
								Manual Entry (No Masterlist)
							</div>
						</div>
					</button>
				))}
			</div>

			<script>
				import { showToast } from '../../lib/toasts';
				const urlParams = new URLSearchParams(window.location.search);
				if (urlParams.get('success') === 'true') {
					showToast('Section created successfully!', 'success');
					// Clean URL
					window.history.replaceState({}, document.title, window.location.pathname);
				}
			</script>

			<!-- Tally Station (Initially Hidden) -->
			<div id="tally-station" class="hidden space-y-12 animate-in fade-in slide-in-from-bottom-4 duration-500">
				<div class="flex items-center justify-between p-6 bg-brand-coral/10 border border-brand-coral/20 rounded-2xl">
					<div class="flex items-center gap-4">
						<button onclick="backToSections()" class="p-2 hover:bg-white/10 rounded-lg transition-colors text-white/40 hover:text-white">
							<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
						</button>
						<div>
							<div class="text-[10px] font-bold uppercase tracking-widest text-brand-coral/60">Currently Tallying</div>
							<h2 class="text-2xl font-outfit font-bold" id="active-section-title">Section Name</h2>
						</div>
					</div>
					<div class="flex items-center gap-3">
						<div class="h-8 w-px bg-brand-coral/20"></div>
						<button onclick="backToSections()" class="px-6 py-2 bg-white/5 hover:bg-white/10 rounded-xl text-xs font-bold uppercase tracking-widest transition-all">Finish Batch</button>
					</div>
				</div>
				<div id="candidate-groups" class="space-y-16">
					<!-- Groups will be injected by JS -->
				</div>
		</div>
	</div>

	<!-- Floating Audit / Controls -->
	<div id="audit-panel" class="hidden fixed bottom-8 right-8 z-50 flex flex-col gap-4">
		<div class="bg-black/80 backdrop-blur-xl border border-white/10 p-6 rounded-3xl shadow-2xl w-64 space-y-4">
			<div class="flex items-center justify-between">
				<span class="text-[10px] font-bold uppercase tracking-widest text-white/40">Activity Log</span>
				<button id="undo-btn" class="text-brand-coral hover:text-brand-coral/80 transition-colors flex items-center gap-1 text-[10px] font-bold uppercase">
					<RotateCcw size={12} /> Undo
				</button>
			</div>
			<div id="log-list" class="space-y-2 max-h-48 overflow-y-auto pr-2">
				<p class="text-[10px] text-white/10 italic">Waiting for entry...</p>
			</div>
		</div>
	</div>
</AdminLayout>

<script is:inline define:vars={{ candidates, collegeMapping }}>
	let currentSectionId = '';
	let currentProgram = '';
	let sessionTally = {}; // { candId: count }
	let activityLog = [];

	const positionPriority = (pos) => {
		const p = pos.toLowerCase();
		if (p === 'president') return 0;
		if (p === 'vice president') return 1;
		if (p.includes('senator')) return 2;
		if (p.includes('hr')) return 3;
		return 4;
	};

	const sectionSearch = document.getElementById('section-search');
	const sectionsContainer = document.getElementById('sections-container');
	const tallyStation = document.getElementById('tally-station');
	const activeSectionTitle = document.getElementById('active-section-title');
	const candidateGroups = document.getElementById('candidate-groups');
	const auditPanel = document.getElementById('audit-panel');
	const logList = document.getElementById('log-list');
	const undoBtn = document.getElementById('undo-btn');

	// Live Search
	sectionSearch?.addEventListener('input', (e) => {
		const term = e.target.value.toLowerCase();
		document.querySelectorAll('.section-card').forEach(card => {
			const name = card.dataset.name || '';
			card.classList.toggle('hidden', !name.includes(term));
		});
	});

	window.selectSection = async (id, name, program) => {
		currentSectionId = id;
		currentProgram = program;
		activeSectionTitle.innerText = name;
		
		// Fetch existing tallies for this section to pre-populate cards
		try {
			const response = await fetch(`/api/manual-get?sectionId=${id}`);
			if (response.ok) {
				const data = await response.json();
				sessionTally = {};
				data.forEach(t => {
					sessionTally[t.candidate_id] = t.votes;
				});
			}
		} catch (err) {
			console.error('Error loading existing tallies:', err);
		}
		
		sectionsContainer.classList.add('hidden');
		tallyStation.classList.remove('hidden');
		auditPanel.classList.remove('hidden');
		document.getElementById('section-search').parentElement.classList.add('hidden');
		
		renderInterface();
	};

	window.backToSections = () => {
		currentSectionId = '';
		currentProgram = '';
		// We don't reset sessionTally here to keep it in memory if needed, 
		// but selectSection will reload it anyway.
		
		sectionsContainer.classList.remove('hidden');
		tallyStation.classList.add('hidden');
		auditPanel.classList.add('hidden');
		document.getElementById('section-search').parentElement.classList.remove('hidden');
	};

	function renderInterface() {
		candidateGroups.innerHTML = '';
		const sectionCollege = collegeMapping[currentProgram] || '';

		// Filter candidates
		const filtered = candidates.filter(c => {
			const pos = c.position.toLowerCase();
			if (pos === 'president' || pos === 'vice president') return true;
			if (pos.includes('senator')) {
				const college = sectionCollege.toLowerCase();
				if (college === 'chtm') {
					return pos.includes('chtm') || pos.includes('chmt');
				}
				return pos.includes(college);
			}
			if (pos.includes('hr')) return pos.includes(currentProgram.toLowerCase());
			return false;
		});

		// Group
		const grouped = filtered.reduce((acc, c) => {
			if (!acc[c.position]) acc[c.position] = [];
			acc[c.position].push(c);
			return acc;
		}, {});

		// Sort positions by priority
		const sortedPos = Object.keys(grouped).sort((a,b) => {
			return positionPriority(a) - positionPriority(b);
		});

		sortedPos.forEach(pos => {
			const section = document.createElement('section');
			section.className = 'space-y-8';
			section.innerHTML = `
				<div class="flex items-center gap-4">
					<h3 class="text-lg font-bold uppercase tracking-[0.2em] text-white/20 whitespace-nowrap">${pos}</h3>
					<div class="h-px bg-white/5 w-full"></div>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
					${grouped[pos].map(c => `
						<div class="bento-card border-white/5 bg-white/[0.02] p-6 flex flex-col gap-6 group hover:border-brand-coral/30 transition-all">
							<div class="flex items-center gap-4">
								<div class="w-10 h-10 bg-white/5 rounded-full flex items-center justify-center text-white/20 font-bold">
									${c.name.charAt(0)}
								</div>
								<div>
									<div class="font-bold text-white group-hover:text-brand-coral transition-colors">${c.name}</div>
									<div class="text-[8px] uppercase tracking-widest text-white/20">Candidate ID: ${c.id.slice(0,8)}</div>
								</div>
							</div>

							<div class="flex items-center justify-between gap-4">
								<input 
									type="number" 
									id="counter-${c.id}" 
									value="${sessionTally[c.id] || 0}" 
									min="0"
									onchange="setTally('${c.id}', '${c.name.replace(/'/g, "\\'")}', this.value)"
									class="w-24 bg-white/5 border border-white/10 rounded-xl px-4 py-2 text-2xl font-outfit font-bold text-brand-coral focus:outline-none focus:border-brand-coral transition-all [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none"
								/>
								<div class="flex gap-2">
									<button onclick="updateTally('${c.id}', '${c.name.replace(/'/g, "\\'")}', -1)" class="w-10 h-10 rounded-xl border border-white/10 flex items-center justify-center hover:bg-white/5 transition-colors text-white/20">
										<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/></svg>
									</button>
									<button onclick="updateTally('${c.id}', '${c.name.replace(/'/g, "\\'")}', 1)" class="flex-1 bg-brand-coral text-white font-bold px-6 py-2 rounded-xl hover:bg-brand-coral/80 transition-all flex items-center justify-center gap-2 shadow-[0_0_20px_rgba(255,85,85,0.1)] active:scale-95">
										<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
										+1
									</button>
								</div>
							</div>
						</div>
					`).join('')}
				</div>
			`;
			candidateGroups.appendChild(section);
		});
	}

	window.updateTally = async (candId, candName, amount) => {
		if (!currentSectionId) return;

		// 1. Update UI (Card Counter)
		sessionTally[candId] = (sessionTally[candId] || 0) + amount;
		const input = document.getElementById(`counter-${candId}`);
		if (input) {
			input.value = sessionTally[candId];
			input.classList.add('border-brand-coral', 'animate-pulse');
			setTimeout(() => input.classList.remove('animate-pulse'), 500);
		}

		// 1.5 Update Global Standing (Sidebar)
		const globalCounter = document.getElementById(`total-${candId}`);
		if (globalCounter) {
			const currentTotal = parseInt(globalCounter.innerText);
			globalCounter.innerText = currentTotal + amount;
			globalCounter.classList.add('animate-pulse');
			setTimeout(() => globalCounter.classList.remove('animate-pulse'), 500);
		}

		// 2. Add to Log
		activityLog.unshift({ candId, candName, amount, time: new Date().toLocaleTimeString() });
		if (activityLog.length > 50) activityLog.pop();
		renderLog();

		// 3. Persist to DB (Real-time update)
		try {
			const response = await fetch('/api/manual-update', {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({ sectionId: currentSectionId, candidateId: candId, amount })
			});
			if (!response.ok) throw new Error('Update failed');
		} catch (err) {
			console.error(err);
			alert('Sync Error! Please check your connection.');
		}
	};

	window.setTally = async (candId, candName, total) => {
		if (!currentSectionId) return;
		const val = parseInt(total) || 0;
		
		const currentInSession = sessionTally[candId] || 0;
		const diff = val - currentInSession;
		
		sessionTally[candId] = val;
		const input = document.getElementById(`counter-${candId}`);
		if (input) {
			input.value = val;
			input.classList.add('border-brand-coral', 'animate-pulse');
			setTimeout(() => input.classList.remove('animate-pulse'), 500);
		}

		const globalCounter = document.getElementById(`total-${candId}`);
		if (globalCounter) {
			const currentTotal = parseInt(globalCounter.innerText);
			globalCounter.innerText = currentTotal + diff;
			globalCounter.classList.add('animate-pulse');
			setTimeout(() => globalCounter.classList.remove('animate-pulse'), 500);
		}

		activityLog.unshift({ candId, candName, amount: diff, time: new Date().toLocaleTimeString(), type: 'input' });
		if (activityLog.length > 50) activityLog.pop();
		renderLog();

		try {
			const response = await fetch('/api/manual-update', {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({ sectionId: currentSectionId, candidateId: candId, total: val })
			});
			if (!response.ok) throw new Error('Update failed');
		} catch (err) {
			console.error(err);
			alert('Sync Error!');
		}
	};

	function renderLog() {
		logList.innerHTML = activityLog.map((item, index) => `
			<div class="flex items-center justify-between text-[10px] border-l-2 ${item.amount > 0 ? 'border-emerald-500' : 'border-red-500'} pl-2 py-1">
				<div class="flex flex-col">
					<span class="font-bold">${item.candName}</span>
					<span class="text-white/40">${item.time}</span>
				</div>
				<span class="font-mono font-bold ${item.amount > 0 ? 'text-emerald-500' : 'text-red-500'}">
					${item.amount > 0 ? '+' : ''}${item.amount}
				</span>
			</div>
		`).join('') || '<p class="text-[10px] text-white/10 italic">Waiting for entry...</p>';
	}

	undoBtn.addEventListener('click', () => {
		if (activityLog.length === 0) return;
		const last = activityLog[0];
		updateTally(last.candId, last.candName, -last.amount);
		// Remove both the mistake and the undo from log to keep it clean
		activityLog.shift(); // remove the undo we just added
		activityLog.shift(); // remove the original mistake
		renderLog();
	});
</script>

