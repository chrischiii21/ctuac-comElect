---
import VoterLayout from '../layouts/VoterLayout.astro';
import { Landmark } from 'lucide-react';
---

<VoterLayout title="COMELEC | Live Election Portal">
	<div class="text-center space-y-12 max-w-2xl mx-auto">
		<div class="flex flex-col items-center gap-6">
			<div class="relative group">
				<div class="absolute inset-0 bg-brand-coral/20 blur-2xl rounded-full group-hover:bg-brand-coral/30 transition-all"></div>
				<img 
					src="/logo.jpg" 
					alt="CTU Logo" 
					class="relative w-24 h-24 object-contain rounded-full shadow-[0_0_50px_rgba(255,85,85,0.3)] border-2 border-white/5 transition-transform group-hover:scale-105 duration-500" 
				/>
			</div>
			<div class="space-y-2">
				<h1 class="text-6xl md:text-8xl font-outfit font-bold tracking-tighter">
					COME<span class="text-brand-coral">LEC</span>
				</h1>
				<p class="text-white/20 font-mono text-sm tracking-[0.5em] uppercase">Student Government Elections</p>
			</div>
		</div>

		<div class="p-1 w-full max-w-md mx-auto bg-gradient-to-r from-transparent via-white/10 to-transparent my-8"></div>

		<div class="space-y-8">
			<p class="text-white/40 text-lg leading-relaxed">
				Welcome to the official live turnout portal. Please use the unique link provided to your section to cast your vote and monitor real-time results.
			</p>
			
			<div class="flex flex-col items-center justify-center">
				<button 
					onclick="document.getElementById('admin-gate').showModal()"
					class="btn-primary px-10 py-4 rounded-2xl flex items-center justify-center gap-3 group transition-all"
				>
					<Landmark size={20} class="text-black group-hover:scale-110 transition-transform" />
					<span>Admin Portal</span>
				</button>
			</div>
		</div>

		<!-- Admin Security Modal -->
		<dialog id="admin-gate" class="bg-brand-black border border-white/10 rounded-3xl p-0 overflow-hidden max-w-sm w-full shadow-[0_0_50px_rgba(0,0,0,0.8)] text-white">
			<div class="p-8 space-y-6">
				<div class="text-center space-y-2">
					<h3 class="text-2xl font-outfit font-bold text-white">Authorized Access</h3>
					<p class="text-white/40 text-sm">Please enter the security key to continue.</p>
				</div>

				<div class="space-y-4">
					<div class="relative group/pass">
						<input 
							type="password" 
							id="passkey" 
							placeholder="••••••••" 
							class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-center text-xl tracking-[0.5em] focus:outline-none focus:border-brand-coral transition-colors text-white placeholder:text-white/10"
						/>
						<button 
							type="button"
							onclick="togglePasskey()"
							class="absolute right-4 top-1/2 -translate-y-1/2 text-white/20 hover:text-white/60 transition-colors"
							id="toggle-btn"
							title="Toggle visibility"
						>
							<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
						</button>
					</div>
					<button 
						onclick="validateAccess()"
						class="w-full bg-brand-coral text-white font-bold py-4 rounded-xl hover:bg-brand-coral/80 transition-colors shadow-[0_0_20px_rgba(255,85,85,0.2)]"
					>
						Enter Dashboard
					</button>
				</div>
				
				<button 
					onclick="this.closest('dialog').close()"
					class="w-full text-[10px] uppercase tracking-widest text-white/40 hover:text-white transition-colors"
				>
					Cancel
				</button>
			</div>
		</dialog>

		<script is:inline>
			function togglePasskey() {
				const input = document.getElementById('passkey');
				const btn = document.getElementById('toggle-btn');
				if (input.type === 'password') {
					input.type = 'text';
					input.style.letterSpacing = '0.1em';
					btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.88 9.88a3 3 0 1 0 4.24 4.24"/><path d="M10.73 5.08A10.43 10.43 0 0 1 12 5c7 0 10 7 10 7a13.16 13.16 0 0 1-1.67 2.68"/><path d="M6.61 6.61A13.52 13.52 0 0 0 2 12s3 7 10 7a9.74 9.74 0 0 0 5.39-1.61"/><line x1="2" x2="22" y1="2" y2="22"/></svg>';
				} else {
					input.type = 'password';
					input.style.letterSpacing = '0.5em';
					btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>';
				}
			}

			function validateAccess() {
				const key = document.getElementById('passkey').value;
				if (key === 'CTUAC2026') {
					// Set a cookie that expires in 1 day
					document.cookie = "admin_access=CTUAC2026; path=/; max-age=86400; samesite=strict";
					window.location.href = '/admin/consolidated';
				} else {
					alert('Invalid Security Key');
					document.getElementById('passkey').value = '';
				}
			}

			// Also allow 'Enter' key
			document.getElementById('passkey')?.addEventListener('keypress', (e) => {
				if (e.key === 'Enter') validateAccess();
			});
		</script>

		<div class="pt-24 grid grid-cols-3 gap-8">
			<div class="text-center">
				<div class="text-2xl font-bold font-outfit">Real-time</div>
				<div class="text-[10px] uppercase tracking-widest text-white/20 mt-1">Updates</div>
			</div>
			<div class="text-center border-x border-white/5">
				<div class="text-2xl font-bold font-outfit">Secure</div>
				<div class="text-[10px] uppercase tracking-widest text-white/20 mt-1">Verification</div>
			</div>
			<div class="text-center">
				<div class="text-2xl font-bold font-outfit">Transparent</div>
				<div class="text-[10px] uppercase tracking-widest text-white/20 mt-1">Live Feed</div>
			</div>
		</div>
	</div>
</VoterLayout>
