---
import VoterLayout from '../../../layouts/VoterLayout.astro';
import { supabase, getSupabaseAdmin } from '../../../lib/supabase';
import { Check, Vote, Landmark } from 'lucide-react';

const { token } = Astro.params;
const studentId = Astro.url.searchParams.get('studentId');

if (!studentId) {
  return Astro.redirect(`/section/${token}`);
}

// 1. Fetch Election Status
const { data: statusData } = await supabase.from('settings').select('value').eq('key', 'election_status').single();
const isElectionActive = statusData?.value?.active ?? true;

if (!isElectionActive) {
  return Astro.redirect('/closed');
}

// 2. Fetch Student & Section
const { data: section } = await supabase.from('sections').select('*').eq('token', token).single();

if (!section) {
  return Astro.redirect('/');
}

const { data: student } = await supabase.from('students').select('*').eq('id', studentId).eq('section_id', section.id).single();

if (!student || student.has_voted) {
  return Astro.redirect(`/section/${token}?error=already_voted`);
}

// 2. Fetch Candidates
const { data: allCandidates } = await supabase.from('candidates').select('*').order('position');

const collegeMapping: Record<string, string> = {
  'BEED': 'CoEd', 'BSED - Math': 'CoEd', 'BSED - English': 'CoEd', 'BTLED': 'CoEd',
  'BSTM': 'CHTM', 'BSHM': 'CHTM',
  'BAEL': 'CAS', 'BAL': 'CAS', 'BSP': 'CAS',
  'BSA': 'CAFE', 'BSF': 'CAFE', 'BSES': 'CAFE',
  'BIT-AT': 'COTE', 'BIT-ET': 'COTE', 'BIT-CT': 'COTE', 'BIT-GT': 'COTE', 'BIT-DT': 'COTE', 'BSIT': 'COTE', 'BSIE': 'COTE',
};

const sectionProgram = section.program || '';
const sectionCollege = collegeMapping[sectionProgram] || '';

// Filter candidates based on section scope
const candidates = allCandidates?.filter(c => {
  const pos = c.position.toLowerCase();
  
  // 1. Executive Board is global
  if (pos === 'president' || pos === 'vice president') return true;
  
  // 2. Senators filtered by College (e.g., "CAS Senator")
  if (pos.includes('senator')) {
    const college = sectionCollege.toLowerCase();
    if (college === 'chtm') {
      return pos.includes('chtm') || pos.includes('chmt');
    }
    return pos.includes(college);
  }
  
  // 3. HR filtered by Program (e.g., "BAEL HR")
  if (pos.includes('hr')) {
    return pos.includes(sectionProgram.toLowerCase());
  }
  
  return false;
}) || [];

// Group candidates by position
const positionPriority = (pos: string) => {
  if (pos === 'President') return 0;
  if (pos === 'Vice President') return 1;
  if (pos.toLowerCase().includes('senator')) return 2;
  if (pos.toLowerCase().includes('hr')) return 3;
  return 4;
};

const categories = [
  { name: 'Executive Board', filter: (pos: string) => pos === 'President' || pos === 'Vice President' },
  { name: 'Senatorial Race', filter: (pos: string) => pos.toLowerCase().includes('senator') },
  { name: 'House Representatives', filter: (pos: string) => pos.toLowerCase().includes('hr') },
];

const groupedCandidates = candidates?.reduce((acc, candidate) => {
  if (!acc[candidate.position]) acc[candidate.position] = [];
  acc[candidate.position].push(candidate);
  return acc;
}, {} as Record<string, any[]>) || {};

const sortedPositions = Object.keys(groupedCandidates).sort((a, b) => {
  const priorityA = positionPriority(a);
  const priorityB = positionPriority(b);
  if (priorityA !== priorityB) return priorityA - priorityB;
  return a.localeCompare(b);
});

// 3. Handle Voting
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  // Collect all selected candidate IDs from all position groups
  const selectedCandidates = Array.from(formData.entries())
    .filter(([name]) => name.startsWith('candidate-'))
    .map(([_, value]) => value as string);

  if (selectedCandidates.length > 0) {
    const admin = getSupabaseAdmin();
    
    // Update candidate counts using admin client to ensure permissions
    for (const id of selectedCandidates) {
      await admin.rpc('increment_vote', { candidate_id: id });
      
      // NEW: Record vote in the votes table for per-section breakdown
      const { error: vError } = await admin.from('votes').insert({
        section_id: section.id,
        candidate_id: id
      });
      if (vError) console.error(`Error recording vote for ${id}:`, vError);
    }

    // Mark student as voted using admin client
    const { error } = await admin
      .from('students')
      .update({ has_voted: true, voted_at: new Date().toISOString() })
      .eq('id', studentId);

    if (!error) {
      return Astro.redirect(`/section/${token}?success=voted`);
    } else {
      console.error('Error marking student as voted:', error);
    }
  }
}
---

<VoterLayout title="Official Ballot | COMELEC">
	<div class="w-full max-w-3xl py-12">
		<header class="text-center mb-12 space-y-4">
			<div class="inline-flex items-center gap-3 px-4 py-2 rounded-2xl bg-white/5 border border-white/10 text-white/40 text-sm font-medium">
				<Landmark size={18} />
				CTU Student Government Election 2026
			</div>
			<h1 class="text-4xl md:text-6xl font-outfit font-bold tracking-tight">Official Ballot</h1>
			<p class="text-white/40">
				Authenticated as <span class="text-emerald-400 font-semibold">{student.full_name}</span>
			</p>
		</header>

		<form method="POST" class="space-y-16">
			{categories.map((cat) => {
				const catPositions = sortedPositions.filter(cat.filter);
				if (catPositions.length === 0) return null;

				return (
					<div class="space-y-10">
						<div class="flex items-center gap-4">
							<h2 class="text-3xl font-outfit font-bold text-emerald-500 whitespace-nowrap">{cat.name}</h2>
							<div class="h-px bg-emerald-500/10 w-full"></div>
						</div>

						<div class="space-y-12">
							{catPositions.map((position) => {
								const list = groupedCandidates[position];
								return (
									<section class="space-y-6">
										<div class="flex items-center gap-4">
											<h3 class="text-lg font-bold uppercase tracking-[0.2em] text-white/20 whitespace-nowrap">{position}</h3>
											<div class="h-px bg-white/5 w-full"></div>
										</div>
										
										<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
											{list.map((candidate) => (
												<label class="relative group cursor-pointer">
													<input 
														type="radio" 
														name={`candidate-${position}`} 
														value={candidate.id} 
														class="peer sr-only" 
													/>
													<div class="bento-card border-white/5 bg-white/[0.02] peer-checked:border-brand-coral peer-checked:bg-brand-coral/10 transition-all duration-300 p-6 flex items-center justify-between group-hover:bg-white/[0.05]">
														<div class="flex items-center gap-4">
															<div class="relative">
																{candidate.image_url ? (
																	<img src={candidate.image_url} alt={candidate.name} class="w-14 h-14 rounded-full object-cover border-2 border-white/10 peer-checked:border-brand-coral transition-colors shadow-lg" />
																) : (
																	<div class="w-14 h-14 bg-white/5 rounded-full flex items-center justify-center text-white/20 font-bold text-xl peer-checked:bg-brand-coral peer-checked:text-white transition-colors">
																		{candidate.name.charAt(0)}
																	</div>
																)}
															</div>
															<div>
																<div class="font-bold text-lg group-hover:text-brand-coral transition-colors">{candidate.name}</div>
																<div class="text-[10px] uppercase tracking-widest text-white/20">Candidate ID: {candidate.id.slice(0,8)}</div>
															</div>
														</div>
														<div class="w-6 h-6 rounded-full border-2 border-white/10 flex items-center justify-center peer-checked:border-brand-coral peer-checked:bg-brand-coral">
															<Check size={14} class="text-white scale-0 peer-checked:scale-100 transition-transform" />
														</div>
													</div>
												</label>
											))}
										</div>
									</section>
								);
							})}
						</div>
					</div>
				);
			})}

			<div class="pt-12 border-t border-white/5 flex flex-col items-center gap-6">
				<div class="text-center space-y-2">
					<h3 class="text-lg font-semibold">Review Your Selections</h3>
					<p class="text-white/20 text-xs italic">By submitting this ballot, you confirm that your choices are final.</p>
				</div>
				<button 
					type="button" 
					class="btn-primary px-12 py-5 rounded-2xl flex items-center gap-3 text-lg group shadow-[0_0_50px_rgba(255,85,85,0.2)]"
					onclick="handleVoteClick()"
				>
					<Vote size={24} />
					Cast My Final Vote
					<span class="group-hover:translate-x-1 transition-transform">→</span>
				</button>
			</div>

			<!-- Vote Confirmation Modal -->
			<dialog id="vote-modal" class="bg-brand-black border border-white/10 rounded-3xl p-0 overflow-hidden max-w-md w-full shadow-[0_0_50px_rgba(0,0,0,0.5)]">
				<div class="p-8 space-y-6">
					<div id="modal-icon" class="w-16 h-16 bg-brand-coral/10 text-brand-coral rounded-2xl flex items-center justify-center">
						<Vote size={32} />
					</div>
					
					<div class="space-y-2">
						<h3 id="modal-title" class="text-2xl font-outfit font-semibold text-white">Cast your vote?</h3>
						<p id="modal-description" class="text-white/60 text-sm">Once you submit, your ballot will be final and you will not be able to change your vote or vote again.</p>
					</div>

					<div id="abstain-warning" class="hidden p-4 bg-amber-500/10 border border-amber-500/20 rounded-xl space-y-2">
						<div class="flex items-center gap-2 text-amber-500 font-bold text-xs uppercase tracking-widest">
							<span class="relative flex h-2 w-2">
								<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-amber-500 opacity-75"></span>
								<span class="relative inline-flex rounded-full h-2 w-2 bg-amber-500"></span>
							</span>
							Abstain Warning
						</div>
						<p class="text-[10px] text-amber-500/60 leading-relaxed">
							You have not selected candidates for some positions. Submitting now will count as an **Abstain** for those races.
						</p>
					</div>
					
					<div class="flex flex-col sm:flex-row gap-3">
						<button type="button" onclick="this.closest('dialog').close()" class="flex-1 px-6 py-4 rounded-xl border border-white/10 text-white/60 hover:bg-white/5 transition-colors font-medium">Wait, Review</button>
						<button type="submit" class="flex-1 btn-primary py-4 rounded-xl font-bold">Yes, Submit Vote</button>
					</div>
				</div>
			</dialog>
		</form>
	</div>
</VoterLayout>

<script is:inline define:vars={{ sortedPositions }}>
	window.handleVoteClick = function() {
		const form = document.querySelector('form');
		const formData = new FormData(form);
		const modal = document.getElementById('vote-modal');
		const abstainWarning = document.getElementById('abstain-warning');
		const modalTitle = document.getElementById('modal-title');
		const modalDesc = document.getElementById('modal-description');
		const modalIcon = document.getElementById('modal-icon');

		// Check how many positions have been voted for
		const votedPositions = Array.from(formData.keys()).filter(key => key.startsWith('candidate-')).length;
		const totalPositions = sortedPositions.length;

		if (votedPositions < totalPositions) {
			// Show Abstain Warning
			abstainWarning.classList.remove('hidden');
			modalTitle.innerText = "Submit & Abstain?";
			modalDesc.innerText = `You've only voted for ${votedPositions} out of ${totalPositions} positions. You can still submit, but unselected races will count as no vote.`;
			modalIcon.classList.replace('text-brand-coral', 'text-amber-500');
			modalIcon.classList.replace('bg-brand-coral/10', 'bg-amber-500/10');
		} else {
			// All filled
			abstainWarning.classList.add('hidden');
			modalTitle.innerText = "Cast your vote?";
			modalDesc.innerText = "Once you submit, your ballot will be final and you will not be able to change your vote or vote again.";
			modalIcon.classList.replace('text-amber-500', 'text-brand-coral');
			modalIcon.classList.replace('bg-amber-500/10', 'bg-brand-coral/10');
		}

		modal.showModal();
	}
</script>

<style>
	/* Peer-checked animations */
	input:checked ~ .bento-card {
		transform: translateY(-4px);
		box-shadow: 0 10px 30px -10px rgba(255, 85, 85, 0.3);
	}
</style>
