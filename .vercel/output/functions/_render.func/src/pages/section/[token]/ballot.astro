---
import VoterLayout from '../../../layouts/VoterLayout.astro';
import { supabase } from '../../../lib/supabase';
import { Check, Vote, Landmark } from 'lucide-react';

const { token } = Astro.params;
const studentId = Astro.url.searchParams.get('studentId');

if (!studentId) {
  return Astro.redirect(`/section/${token}`);
}

// 1. Fetch Student & Section
const { data: section } = await supabase.from('sections').select('*').eq('token', token).single();
const { data: student } = await supabase.from('students').select('*').eq('student_id', studentId).eq('section_id', section.id).single();

if (!student || student.has_voted) {
  return Astro.redirect(`/section/${token}?error=already_voted`);
}

// 2. Fetch Candidates
const { data: candidates } = await supabase.from('candidates').select('*').order('position');

// Group candidates by position
const groupedCandidates = candidates?.reduce((acc, candidate) => {
  if (!acc[candidate.position]) acc[candidate.position] = [];
  acc[candidate.position].push(candidate);
  return acc;
}, {} as Record<string, any[]>) || {};

// 3. Handle Voting
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const selectedCandidates = formData.getAll('candidateId');

  if (selectedCandidates.length > 0) {
    // Start a simple transaction-like process (sequential updates for simplicity)
    
    // Update candidate counts
    for (const id of selectedCandidates) {
      const { error: rpcError } = await supabase.rpc('increment_vote', { candidate_id: id });
      if (rpcError) console.error('Error incrementing vote:', rpcError);
    }

    // Mark student as voted
    const { error } = await supabase
      .from('students')
      .update({ has_voted: true, voted_at: new Date().toISOString() })
      .eq('student_id', studentId);

    if (!error) {
      return Astro.redirect(`/section/${token}?success=voted`);
    }
  }
}
---

<VoterLayout title="Official Ballot | COMELEC">
	<div class="w-full max-w-3xl py-12">
		<header class="text-center mb-12 space-y-4">
			<div class="inline-flex items-center gap-3 px-4 py-2 rounded-2xl bg-white/5 border border-white/10 text-white/40 text-sm font-medium">
				<Landmark size={18} />
				CTU Student Government Election 2026
			</div>
			<h1 class="text-4xl md:text-6xl font-outfit font-bold tracking-tight">Official Ballot</h1>
			<p class="text-white/40">
				Authenticated as <span class="text-emerald-400 font-semibold">{student.full_name}</span>
			</p>
		</header>

		<form method="POST" class="space-y-12">
			{Object.entries(groupedCandidates).map(([position, list]) => (
				<section class="space-y-6">
					<div class="flex items-center gap-4">
						<h2 class="text-xl font-bold uppercase tracking-[0.2em] text-white/20 whitespace-nowrap">{position}</h2>
						<div class="h-px bg-white/5 w-full"></div>
					</div>
					
					<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
						{list.map((candidate) => (
							<label class="relative group cursor-pointer">
								<input 
									type="radio" 
									name={`candidateId`} 
									value={candidate.id} 
									class="peer sr-only" 
									required
								/>
								<div class="bento-card border-white/5 bg-white/[0.02] peer-checked:border-brand-coral peer-checked:bg-brand-coral/10 transition-all duration-300 p-6 flex items-center justify-between group-hover:bg-white/[0.05]">
									<div class="flex items-center gap-4">
										<div class="relative">
											{candidate.image_url ? (
												<img src={candidate.image_url} alt={candidate.name} class="w-14 h-14 rounded-full object-cover border-2 border-white/10 peer-checked:border-brand-coral transition-colors shadow-lg" />
											) : (
												<div class="w-14 h-14 bg-white/5 rounded-full flex items-center justify-center text-white/20 font-bold text-xl peer-checked:bg-brand-coral peer-checked:text-white transition-colors">
													{candidate.name.charAt(0)}
												</div>
											)}
										</div>
										<div>
											<div class="font-bold text-lg group-hover:text-brand-coral transition-colors">{candidate.name}</div>
											<div class="text-[10px] uppercase tracking-widest text-white/20">Candidate ID: {candidate.id.slice(0,8)}</div>
										</div>
									</div>
									<div class="w-6 h-6 rounded-full border-2 border-white/10 flex items-center justify-center peer-checked:border-brand-coral peer-checked:bg-brand-coral">
										<Check size={14} class="text-white scale-0 peer-checked:scale-100 transition-transform" />
									</div>
								</div>
							</label>
						))}
					</div>
				</section>
			))}

			<div class="pt-12 border-t border-white/5 flex flex-col items-center gap-6">
				<div class="text-center space-y-2">
					<h3 class="text-lg font-semibold">Review Your Selections</h3>
					<p class="text-white/20 text-xs italic">By submitting this ballot, you confirm that your choices are final.</p>
				</div>
				<button 
					type="button" 
					class="btn-primary px-12 py-5 rounded-2xl flex items-center gap-3 text-lg group shadow-[0_0_50px_rgba(255,85,85,0.2)]"
					onclick="document.getElementById('vote-modal').showModal()"
				>
					<Vote size={24} />
					Cast My Final Vote
					<span class="group-hover:translate-x-1 transition-transform">→</span>
				</button>
			</div>

			<!-- Vote Confirmation Modal -->
			<dialog id="vote-modal" class="bg-brand-black border border-white/10 rounded-3xl p-0 overflow-hidden max-w-md w-full">
				<div class="p-8">
					<div class="w-16 h-16 bg-brand-coral/10 text-brand-coral rounded-2xl flex items-center justify-center mb-6">
						<Vote size={32} />
					</div>
					<h3 class="text-2xl font-outfit font-semibold mb-2 text-white">Cast your vote?</h3>
					<p class="text-white/60 text-sm mb-8">Once you submit, your ballot will be final and you will not be able to change your vote or vote again.</p>
					
					<div class="flex gap-4">
						<button type="button" onclick="this.closest('dialog').close()" class="flex-1 px-6 py-3 rounded-xl border border-white/10 text-white/60 hover:bg-white/5 transition-colors">Wait, Go Back</button>
						<button type="submit" class="flex-1 btn-primary py-3 rounded-xl">Yes, Submit Vote</button>
					</div>
				</div>
			</dialog>
		</form>
	</div>
</VoterLayout>

<style>
	/* Peer-checked animations */
	input:checked ~ .bento-card {
		transform: translateY(-4px);
		box-shadow: 0 10px 30px -10px rgba(255, 85, 85, 0.3);
	}
</style>
